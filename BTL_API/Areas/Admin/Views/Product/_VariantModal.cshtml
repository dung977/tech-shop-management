<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg shadow-lg">
        <div class="modal-content border-0">
            <div class="modal-header text-white" style="background-color: #1b45cf;">
                <h5 class="modal-title"><i class="fas fa-box-open me-2"></i>Thêm Sản Phẩm Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="addProductForm">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Tên sản phẩm</label>
                            <input type="text" class="form-control border-primary-subtle" name="ProductName" placeholder="Ví dụ: iPhone 15 Pro Max" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Mã SP (Tự động)</label>
                            <input type="text" class="form-control bg-light" value="Hệ thống tự sinh" disabled>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Thương hiệu</label>
                            <select class="form-select border-primary-subtle" name="Brand">
                                <option value="Apple">Apple</option>
                                <option value="Samsung">Samsung</option>
                                <option value="Xiaomi">Xiaomi</option>
                                <option value="Asus">Asus</option>
                                <option value="Dell">Dell</option>
                                <option value="HP">HP</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Danh mục</label>
                            <select class="form-select border-primary-subtle" name="CategoryID" id="addCategorySelect" onchange="renderDynamicFields()">
                                <option value="CAT8">Laptop</option>
                                <option value="CAT5">Điện thoại</option>
                                <option value="CAT1">Phụ kiện</option>
                                <option value="CAT4">Máy ảnh</option>
                                <option value="CAT11">Máy tính bảng</option>
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold text-primary">Danh sách ảnh (JSON)</label>
                            <textarea class="form-control border-primary-subtle" name="Images" rows="2" placeholder='["https://link-anh-1.png", "https://link-anh-2.png"]'>[]</textarea>
                        </div>

                        <div class="col-12 mt-4">
                            <div class="p-3 rounded-3 border bg-light shadow-sm">
                                <h6 class="fw-bold text-dark mb-3 border-bottom pb-2">
                                    <i class="fas fa-microchip me-2 text-primary"></i>Thông số kỹ thuật chung
                                </h6>
                                <div id="dynamicSpecArea" class="row g-3">
                                    <div class="mt-3 border-top pt-2">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addMoreSpecField()">
                                            <i class="fas fa-plus me-1"></i> Thêm thông số khác 
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light border-top-0">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary px-5 fw-bold" onclick="submitAddProduct()">
                    <i class="fas fa-save me-1"></i> Lưu sản phẩm
                </button>
            </div>
        </div>
    </div>
</div>